# Normalize all text files to LF on commit and checkout
* text=auto eol=lf

# Explicitly binary — never touch line endings
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.zip  binary
*.gz   binary
*.db   binary
*.sqlite binary
*.sqlite3 binary
*.so   binary
*.pyc  binary
*.whl  binary
