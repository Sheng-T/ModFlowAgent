[
  {
    "name": "nextflow_run_nfcore",
    "description": "Run nf-core pipelines via nextflow with singularity profile.",
    "usage": "nextflow run nf-core/<pipeline> -profile singularity --input <samplesheet> --outdir <outdir> [--genome <ref>] [extra args]",
    "args": {
      "kwargs": {
        "pipeline": "nf-core pipeline name, e.g. methylong/rnaseq/sarek/ampliseq/methylseq/mag/taxprofiler",
        "input": "Input samplesheet path.",
        "outdir": "Output directory.",
        "profile": "Execution profile, default singularity.",
        "genome": "Optional genome key in iGenomes or pipeline-specific reference setting.",
        "config": "Optional nextflow config path.",
        "extra_args": "Optional flags such as -resume -with-report -with-trace -with-timeline."
      }
    }
  }
]
